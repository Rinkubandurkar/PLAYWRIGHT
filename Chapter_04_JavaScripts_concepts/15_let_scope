let a = 10;
// var is actually a funtion scoped

console.log(a); // 10  // global scope

function printHello() {
    console.log("Hello The testing academy");
    let a = 20;    // local scope
    console.log(a); // 20
    if (true) {
        var a = 30;
        console.log(a); // 30
    } console.log("F --> ", a);
}
printHello();

console.log("G --> ", a); // Global --> 10
// Hello The testing academy